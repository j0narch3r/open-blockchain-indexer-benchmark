{
  "name": "squid-evm-template",
  "private": true,
  "scripts": {
    "build": "rm -rf lib && tsc",
    "codegen": "npx squid-typeorm-codegen",
    "db:migrate": "npx squid-typeorm-migration apply",
    "db:generate": "npx squid-typeorm-migration generate",
    "typegen": "npx squid-evm-typegen src/abi"
  },
  "dependencies": {
    "@subsquid/evm-abi": "^0.3.1",
    "@subsquid/evm-processor": "^1.27.3",
    "@subsquid/graphql-server": "^4.11.0",
    "@subsquid/typeorm-migration": "^1.3.0",
    "@subsquid/typeorm-store": "^1.6.0",
    "@subsquid/util-internal": "^3.2.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.7",
    "pg": "^8.15.6",
    "typeorm": "^0.3.22",
    "web3": "^4.16.0"
  },
  "devDependencies": {
    "@subsquid/evm-typegen": "^4.5.1",
    "@subsquid/typeorm-codegen": "^2.0.2",
    "@types/node": "^20.17.32",
    "typescript": "~5.5.2"
  }
}